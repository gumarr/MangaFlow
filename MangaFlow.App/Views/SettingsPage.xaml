<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MangaFlow.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MangaFlow.App.ViewModels"
    xmlns:helpers="using:MangaFlow.App.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer Padding="32,24,32,24">
        <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Settings" Style="{ThemeResource HeaderTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="Configure OCR engine, hotkeys, and language preferences" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- OCR Settings Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="OCR Settings" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="24">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="OCR Engine" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <ComboBox SelectedItem="{x:Bind ViewModel.OcrEngine, Mode=TwoWay}" Width="240">
                                <x:String>RapidOCR</x:String>
                                <x:String>Stub</x:String>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Default OCR Language" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <ComboBox SelectedItem="{x:Bind ViewModel.OcrLanguage, Mode=TwoWay}" Width="240" IsEnabled="False">
                                <x:String>English</x:String>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock Text="OCR Model Path (ONNX/keys directory)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                            <TextBox Grid.Column="0" Text="{x:Bind ViewModel.OcrModelPath, Mode=TwoWay}" PlaceholderText="C:\models\ocr" />
                            <Button Grid.Column="1" Content="Browse..." Style="{ThemeResource DefaultButtonStyle}" Click="OnBrowseOcrModelPathClick" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- LLM Model Settings Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="LLM Translation Model" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                        <TextBlock Text="Local GGUF model used for English → Vietnamese translation (llama.cpp backend)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Model File Path (.gguf)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                            <TextBox Grid.Column="0" Text="{x:Bind ViewModel.LlmModelPath, Mode=TwoWay}" PlaceholderText="C:\models\Qwen3-8B-Q4_K_M.gguf" />
                            <Button Grid.Column="1" Content="Browse..." Style="{ThemeResource DefaultButtonStyle}" Click="OnBrowseLlmModelPathClick" />
                        </Grid>
                        <TextBlock Text="Recommended: Qwen3-8B-Instruct-Q4_K_M.gguf — download from Hugging Face (see guide below)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="24">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="CPU Threads" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <NumberBox Value="{x:Bind ViewModel.CpuThreads, Mode=TwoWay}" Minimum="1" Maximum="32" SmallChange="1" SpinButtonPlacementMode="Compact" Width="160" />
                            <TextBlock Text="Set to number of physical cores (not logical)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Temperature" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <NumberBox Value="{x:Bind ViewModel.Temperature, Mode=TwoWay}" Minimum="0.0" Maximum="2.0" SmallChange="0.05" SpinButtonPlacementMode="Compact" Width="160" />
                            <TextBlock Text="0.1–0.4 for consistent translation, higher = more creative" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="24">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Context Size (tokens)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <NumberBox Value="{x:Bind ViewModel.ContextSize, Mode=TwoWay}" Minimum="512" Maximum="8192" SmallChange="512" SpinButtonPlacementMode="Compact" Width="160" />
                            <TextBlock Text="2048 is plenty for manga bubbles. Larger = slower load + more RAM/VRAM." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="GPU Layers" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <NumberBox Value="{x:Bind ViewModel.GpuLayerCount, Mode=TwoWay}" Minimum="0" Maximum="99" SmallChange="1" SpinButtonPlacementMode="Compact" Width="160" IsEnabled="{x:Bind ViewModel.UseGpu, Mode=OneWay}" />
                            <TextBlock Text="99 = offload all layers to GPU. Lower if VRAM is limited. Ignored when GPU is off." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <ToggleSwitch Header="Use GPU Acceleration (NVIDIA CUDA)" IsOn="{x:Bind ViewModel.UseGpu, Mode=TwoWay}" />
                    <TextBlock Text="Requires an NVIDIA GPU + CUDA 12 runtime. Falls back to CPU automatically if unavailable." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button Content="Apply &amp; Reload Model" Command="{x:Bind ViewModel.ReloadModelCommand}" />
                            <ProgressRing IsActive="{x:Bind ViewModel.IsReloadingModel, Mode=OneWay}" Width="20" Height="20" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.BackendStatusText, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" MaxWidth="600" HorizontalAlignment="Left" />
                        <TextBlock Text="Reload after changing model path, threads, context, or GPU options." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- General Settings Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="General &amp; Hotkeys" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Global Capture Hotkey" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBox Text="{x:Bind ViewModel.GlobalHotkey, Mode=TwoWay}" Width="240" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="24">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Default Source Language" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{x:Bind ViewModel.DefaultSourceLanguage, Mode=TwoWay}" Width="240" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Default Target Language" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{x:Bind ViewModel.DefaultTargetLanguage, Mode=TwoWay}" Width="240" />
                        </StackPanel>
                    </Grid>

                    <ToggleSwitch Header="Show Capture Image Preview (Developer mode)" IsOn="{x:Bind ViewModel.ShowCapturePreview, Mode=TwoWay}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="Translation Memory" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button Content="Clear Translation Memory" Command="{x:Bind ViewModel.ClearTranslationMemoryCommand}" />
                            <TextBlock Text="{x:Bind ViewModel.ClearTmStatusText, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="Clears all cached translations. Next capture will re-translate via LLM." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Save Action Button -->
            <Button Content="Save Settings" 
                    Command="{x:Bind ViewModel.SaveSettingsCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    Padding="24,12,24,12"
                    HorizontalAlignment="Right" />

            <!-- Saving Indicator -->
            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{x:Bind ViewModel.IsSaving, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right">
                <ProgressRing IsActive="True" Width="20" Height="20" />
                <TextBlock Text="Saving settings..." Style="{ThemeResource BodyTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
