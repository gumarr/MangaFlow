<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MangaFlow.App.Views.TranslationPlaygroundPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:MangaFlow.App.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:BooleanNegationConverter x:Key="BoolNeg" />
    </Page.Resources>

    <Grid Padding="32,24,32,24" RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Translation Playground" Style="{ThemeResource HeaderTextBlockStyle}" FontWeight="Bold" />
            <TextBlock Text="Test the local LLM translation pipeline with custom OCR text input"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Model Status Bar -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <FontIcon Grid.Column="0" Glyph="&#xE9D9;" FontSize="16"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                          VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="{x:Bind ViewModel.ModelNameText, Mode=OneWay}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.ModelStatusText, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="{x:Bind ViewModel.ContextLengthText, Mode=OneWay}"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button Grid.Column="3"
                        Content="Load Model"
                        Command="{x:Bind ViewModel.LoadModelCommand}"
                        IsEnabled="{x:Bind ViewModel.IsModelLoaded, Converter={StaticResource BoolNeg}, Mode=OneWay}"
                        Style="{ThemeResource AccentButtonStyle}" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="24" RowDefinitions="*,Auto">

            <!-- Left: OCR Input -->
            <Border Grid.Column="0" Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="OCR Text (English Source)"
                               Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <TextBox Grid.Row="1"
                             Text="{x:Bind ViewModel.SourceText, Mode=TwoWay}"
                             PlaceholderText="Paste or type English OCR text here..."
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             FontFamily="Consolas"
                             FontSize="14"
                             BorderThickness="1"
                             CornerRadius="4" />
                    <Button Grid.Row="2"
                            Content="Translate"
                            Command="{x:Bind ViewModel.TranslateCommand}"
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0,12,0,0"
                            IsEnabled="{x:Bind ViewModel.IsTranslating, Converter={StaticResource BoolNeg}, Mode=OneWay}" />
                </Grid>
            </Border>

            <!-- Right: Translation Output -->
            <Border Grid.Column="1" Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Vietnamese Translation"
                               Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <Grid Grid.Row="1">
                        <TextBox Text="{x:Bind ViewModel.TranslatedText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontSize="15"
                                 BorderThickness="1"
                                 CornerRadius="4"
                                 PlaceholderText="Translation will appear here..." />
                        <!-- Translating overlay -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                Opacity="0.85"
                                CornerRadius="4"
                                Visibility="{x:Bind ViewModel.IsTranslating, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                                <ProgressRing IsActive="True" Width="40" Height="40" />
                                <TextBlock Text="Running LLM inference..." FontWeight="SemiBold" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Diagnostics Bar -->
            <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,14" Margin="0,20,0,0">
                <Grid ColumnDefinitions="*,*,*,*,*,*,*,*">

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Execution Time" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ExecutionTimeText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Tokens/sec" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TokensPerSecText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Cache" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CacheStatusText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="Model" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ModelNameText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="4" Spacing="2">
                        <TextBlock Text="Context Length" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ContextLengthText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="5" Spacing="2">
                        <TextBlock Text="Glossary Terms" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.GlossaryTermsUsedText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="6" Spacing="2">
                        <TextBlock Text="Bubble Context" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.BubbleCountText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="7" Spacing="2">
                        <TextBlock Text="Prompt Size" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.PromptSizeText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
