<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MangaFlow.App.Views.CaptureResultWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Translation Tooltip">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" HorizontalAlignment="Stretch">
                    <!-- Translated Text (Vietnamese) -->
                    <TextBlock x:Name="TranslationTextBlock"
                               Text="{x:Bind ViewModel.TranslatedText, Mode=OneWay}"
                               IsTextSelectionEnabled="True"
                               TextWrapping="Wrap"
                               FontFamily="Segoe UI, Segoe UI Variable"
                               FontSize="18"
                               FontWeight="SemiBold"
                               LineHeight="26"
                               LineStackingStrategy="BlockLineHeight"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Stretch"/>

                    <!-- Separator line -->
                    <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" 
                            BorderThickness="0,0,0,1" 
                            Height="1" 
                            Margin="0,4,0,4"
                            HorizontalAlignment="Stretch"/>

                    <!-- Original Text (English) -->
                    <TextBlock x:Name="OcrTextBlock"
                               Text="{x:Bind ViewModel.RecognizedText, Mode=OneWay}"
                               IsTextSelectionEnabled="True"
                               TextWrapping="Wrap"
                               FontFamily="Segoe UI, Segoe UI Variable"
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               LineHeight="20"
                               LineStackingStrategy="BlockLineHeight"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Stretch"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
