<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MangaFlow.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MangaFlow.App.ViewModels"
    xmlns:helpers="using:MangaFlow.App.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer Padding="32,24,32,24">
        <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">
            <!-- Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Settings" Style="{ThemeResource HeaderTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="Configure translation models, OCR engine, and performance preferences" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- OCR Settings Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="OCR Settings" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Default OCR Language" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <ComboBox SelectedItem="{x:Bind ViewModel.OcrLanguage, Mode=TwoWay}" Width="240">
                            <x:String>Japanese</x:String>
                            <x:String>English</x:String>
                            <x:String>Chinese</x:String>
                            <x:String>Korean</x:String>
                            <x:String>Vietnamese</x:String>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- LLM Engine Settings Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="AI Translation Model" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Translation Model type" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <ComboBox SelectedItem="{x:Bind ViewModel.SelectedLlmModel, Mode=TwoWay}" Width="240">
                            <x:String>Qwen 3 8B GGUF</x:String>
                            <x:String>Qwen 4B</x:String>
                            <x:String>Qwen 14B</x:String>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Local Model Path (.gguf)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                            <TextBox Grid.Column="0" Text="{x:Bind ViewModel.LlmModelPath, Mode=TwoWay}" PlaceholderText="C:\models\qwen-8b.gguf" />
                            <Button Grid.Column="1" Content="Browse..." Style="{ThemeResource DefaultButtonStyle}" />
                        </Grid>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="24">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="CPU Inference Threads" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <NumberBox Value="{x:Bind ViewModel.CpuThreads, Mode=TwoWay}" SmallChange="1" LargeChange="2" SpinButtonPlacementMode="Compact" Minimum="1" Maximum="32" Width="160" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Temperature" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <Slider Value="{x:Bind ViewModel.Temperature, Mode=TwoWay}" Minimum="0.0" Maximum="1.0" StepFrequency="0.05" Width="240" />
                        </StackPanel>
                    </Grid>

                    <ToggleSwitch Header="Use GPU Acceleration (llama.cpp CUDA/Vulkan)" IsOn="{x:Bind ViewModel.UseGpu, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- General Settings Card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="General &amp; Hotkeys" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Global Capture Hotkey" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBox Text="{x:Bind ViewModel.GlobalHotkey, Mode=TwoWay}" Width="240" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="24">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="Default Source Language" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{x:Bind ViewModel.DefaultSourceLanguage, Mode=TwoWay}" Width="240" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="Default Target Language" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{x:Bind ViewModel.DefaultTargetLanguage, Mode=TwoWay}" Width="240" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save Action Button -->
            <Button Content="Save Settings" 
                    Command="{x:Bind ViewModel.SaveSettingsCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    Padding="24,12,24,12"
                    HorizontalAlignment="Right" />

            <!-- Saving Indicator -->
            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{x:Bind ViewModel.IsSaving, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Right">
                <ProgressRing IsActive="True" Width="20" Height="20" />
                <TextBlock Text="Saving settings..." Style="{ThemeResource BodyTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
