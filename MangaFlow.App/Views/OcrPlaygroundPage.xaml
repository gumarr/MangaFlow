<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MangaFlow.App.Views.OcrPlaygroundPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:MangaFlow.App.ViewModels"
    xmlns:helpers="using:MangaFlow.App.Helpers"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <helpers:BooleanNegationConverter x:Key="BooleanNegationConverter"/>
    </Page.Resources>

    <Grid Padding="36" RowDefinitions="Auto,*">
        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="OCR Playground" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
            <TextBlock Text="Test the OCR engine by uploading localized images and running OCR in real-time."
                       FontSize="14" 
                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="24">
            <!-- Left Side: Image Upload & Preview -->
            <Border Grid.Column="0" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24">
                <Grid RowDefinitions="*,Auto">
                    <!-- Preview Container -->
                    <Border Grid.Row="0" 
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="0,0,0,20"
                            MinHeight="250">
                        <Grid>
                            <!-- Placeholder -->
                            <StackPanel HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        Spacing="12"
                                        Visibility="{x:Bind ViewModel.SelectedImagePreview, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse, Mode=OneWay}">
                                <FontIcon Glyph="&#xEB9F;" FontSize="48" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="No Image Selected" 
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            </StackPanel>
                            <!-- Selected Image -->
                            <Image Source="{x:Bind ViewModel.SelectedImagePreview, Mode=OneWay}" 
                                   Stretch="Uniform" 
                                   Margin="12"
                                   Visibility="{x:Bind ViewModel.SelectedImagePreview, Converter={StaticResource NullToVisibilityConverter}, Mode=OneWay}"/>
                        </Grid>
                    </Border>

                    <!-- Control Buttons -->
                    <StackPanel Grid.Row="1" Spacing="12">
                        <TextBlock Text="Preset English Test Cases" FontWeight="SemiBold" FontSize="14"/>
                        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="Simple" Command="{x:Bind ViewModel.RunTestCaseCommand}" CommandParameter="Simple" HorizontalAlignment="Stretch" IsEnabled="{x:Bind ViewModel.IsRunning, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"/>
                            <Button Grid.Column="1" Content="Paragraph" Command="{x:Bind ViewModel.RunTestCaseCommand}" CommandParameter="Paragraph" HorizontalAlignment="Stretch" IsEnabled="{x:Bind ViewModel.IsRunning, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"/>
                            <Button Grid.Column="2" Content="Mixed" Command="{x:Bind ViewModel.RunTestCaseCommand}" CommandParameter="Mixed" HorizontalAlignment="Stretch" IsEnabled="{x:Bind ViewModel.IsRunning, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"/>
                            <Button Grid.Column="3" Content="Uppercase" Command="{x:Bind ViewModel.RunTestCaseCommand}" CommandParameter="Uppercase" HorizontalAlignment="Stretch" IsEnabled="{x:Bind ViewModel.IsRunning, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"/>
                            <Button Grid.Column="4" Content="Last Capture" Command="{x:Bind ViewModel.LoadLastCaptureCommand}" HorizontalAlignment="Stretch" IsEnabled="{x:Bind ViewModel.IsRunning, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"/>
                        </Grid>
                        
                        <MenuFlyoutSeparator Margin="0,4,0,4"/>

                        <TextBlock Text="{x:Bind ViewModel.SelectedImagePath, Mode=OneWay}" 
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0" 
                                    Content="Select Image" 
                                    Command="{x:Bind ViewModel.SelectImageCommand}" 
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource AccentButtonStyle}"/>
                            <Button Grid.Column="1" 
                                    Content="Run OCR" 
                                    Command="{x:Bind ViewModel.RunOcrCommand}" 
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{x:Bind ViewModel.IsRunning, Converter={StaticResource BooleanNegationConverter}, Mode=OneWay}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Side: OCR Outputs & Metrics -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto" RowSpacing="24">
                <!-- OCR Results Card -->
                <Border Grid.Row="0" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" 
                                   Text="Recognized Text Output" 
                                   FontWeight="SemiBold" 
                                   FontSize="18"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Output Box -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBox Text="{x:Bind ViewModel.OcrResultText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0"
                                     FontFamily="Segoe UI, Segoe UI Variable"
                                     FontSize="15"
                                     PlaceholderText="OCR output will appear here..."/>
                        </ScrollViewer>
                        
                        <!-- Progress Indicator Overlay -->
                        <Grid Grid.Row="1" 
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                              Opacity="0.8" 
                              Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                                <ProgressRing IsActive="True" Width="48" Height="48"/>
                                <TextBlock Text="Running OCR engine..." FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Metrics Card -->
                <Border Grid.Row="1" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Performance &amp; Statistics" 
                                   FontWeight="SemiBold" 
                                   FontSize="16"
                                   Margin="0,0,0,4"/>
                        <Grid ColumnDefinitions="*,*">
                            <TextBlock Grid.Column="0" 
                                        Text="{x:Bind ViewModel.ConfidenceText, Mode=OneWay}" 
                                        FontWeight="Medium"
                                        FontSize="14"/>
                            <TextBlock Grid.Column="1" 
                                        Text="{x:Bind ViewModel.ExecutionTimeText, Mode=OneWay}" 
                                        FontWeight="Medium"
                                        FontSize="14"
                                        HorizontalAlignment="Right"/>
                        </Grid>

                        <MenuFlyoutSeparator Margin="0,4,0,4"/>

                        <TextBlock Text="OCR Engine Startup Diagnostics" 
                                   FontWeight="SemiBold" 
                                   FontSize="14"
                                   Margin="0,4,0,4"/>

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="6" ColumnSpacing="12">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Detector:" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.DetectorPathText, Mode=OneWay}" TextWrapping="Wrap" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Recognizer:" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.RecognizerPathText, Mode=OneWay}" TextWrapping="Wrap" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Dictionary:" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.DictionaryPathText, Mode=OneWay}" TextWrapping="Wrap" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Source:" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.SourceText, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Language:" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.LanguageText, Mode=OneWay}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
