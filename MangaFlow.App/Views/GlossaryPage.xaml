<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MangaFlow.App.Views.GlossaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MangaFlow.App.ViewModels"
    xmlns:entities="using:MangaFlow.Domain.Entities"
    xmlns:helpers="using:MangaFlow.App.Helpers"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Glossary Manager" Style="{ThemeResource HeaderTextBlockStyle}" FontWeight="Bold" />
            <TextBlock Text="Define terminology mappings to ensure translation consistency" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Content Area -->
        <Grid Grid.Row="1" ColumnDefinitions="350, *" ColumnSpacing="24">
            <!-- Left Panel: Filter & Add Form -->
            <StackPanel Grid.Column="0" Spacing="20">
                <!-- Project Filter Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Glossary Scope" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <!-- Project selector (null display custom placeholder) -->
                        <ComboBox ItemsSource="{x:Bind ViewModel.Projects, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedProject, Mode=TwoWay}"
                                  SelectionChanged="OnScopeSelectionChanged"
                                  HorizontalAlignment="Stretch"
                                  x:Name="ScopeComboBox" />
                    </StackPanel>
                </Border>

                <!-- Add Term Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Add New Term" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Source Text (e.g. English)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{x:Bind ViewModel.NewSourceText, Mode=TwoWay}" PlaceholderText="Mana Crystal" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Target Text (e.g. Vietnamese)" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBox Text="{x:Bind ViewModel.NewTargetText, Mode=TwoWay}" PlaceholderText="Tinh Thạch Ma Lực" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Priority" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <NumberBox Value="{x:Bind ViewModel.NewPriority, Mode=TwoWay}" SmallChange="1" LargeChange="5" SpinButtonPlacementMode="Compact" Minimum="0" Maximum="100" Width="120" />
                        </StackPanel>

                        <CheckBox Content="Lock Translation (Force LLM usage)" IsChecked="{x:Bind ViewModel.NewIsLocked, Mode=TwoWay}" />

                        <Button Content="Add Term"
                                Command="{x:Bind ViewModel.AddTermCommand}"
                                Style="{ThemeResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right Panel: Terms List -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
                <Grid RowDefinitions="Auto, *">
                    <Grid Grid.Row="0" ColumnDefinitions="*, *, Auto, Auto, Auto" Padding="12,0,12,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Text="Source Term" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="Translation" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="2" Text="Priority" Style="{ThemeResource BodyStrongTextBlockStyle}" Width="80" TextAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="Locked" Style="{ThemeResource BodyStrongTextBlockStyle}" Width="80" TextAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="Action" Style="{ThemeResource BodyStrongTextBlockStyle}" Width="60" TextAlignment="Center" />
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Terms, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="entities:GlossaryTerm">
                                <Grid ColumnDefinitions="*, *, Auto, Auto, Auto" Padding="0,8,0,8">
                                    <TextBlock Grid.Column="0" Text="{x:Bind SourceText}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind TargetText}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind Priority}" VerticalAlignment="Center" Width="80" TextAlignment="Center" />
                                    <CheckBox Grid.Column="3" IsChecked="{x:Bind IsLocked}" IsEnabled="False" Width="80" HorizontalAlignment="Center" />
                                    <Button Grid.Column="4" 
                                            Content="Delete" 
                                            Click="OnDeleteTermClick"
                                            Style="{ThemeResource DefaultButtonStyle}" 
                                            Foreground="Red" 
                                            Width="60" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
