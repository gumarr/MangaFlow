<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MangaFlow.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MangaFlow.App.ViewModels"
    xmlns:entities="using:MangaFlow.Domain.Entities"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,24">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Translation History" Style="{ThemeResource HeaderTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="Review past OCR translations and fine-tune terminology" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            
            <Button Grid.Column="1" 
                    Content="Clear History" 
                    Command="{x:Bind ViewModel.ClearHistoryCommand}"
                    Style="{ThemeResource DefaultButtonStyle}"
                    Foreground="Red"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="1" RowDefinitions="Auto, *" RowSpacing="16">
            <!-- Project Filter Dropdown -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16">
                <TextBlock Text="Select Project:" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{x:Bind ViewModel.Projects, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedProject, Mode=TwoWay}"
                          SelectionChanged="OnProjectSelectionChanged"
                          DisplayMemberPath="Name"
                          Width="250" />
            </StackPanel>

            <!-- History Log list -->
            <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
                <Grid RowDefinitions="Auto, *">
                    <Grid Grid.Row="0" ColumnDefinitions="*, *, 200" Padding="12,0,12,8" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Text="Original OCR" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="AI Translation" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="2" Text="Timestamp" Style="{ThemeResource BodyStrongTextBlockStyle}" TextAlignment="Right" />
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.HistoryItems, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="entities:TranslationHistoryItem">
                                <Grid ColumnDefinitions="*, *, 200" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,0.5">
                                    <TextBlock Grid.Column="0" Text="{x:Bind SourceText}" TextWrapping="Wrap" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind TranslatedText}" TextWrapping="Wrap" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind CreatedAt}" TextAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
